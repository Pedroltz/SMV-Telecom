@page
@model SMVTelecom.Pages.Parceiras.AudioCodesModel
@using SMVTelecom.Services
@inject ProdutoService _prodSvc
@inject SiteConfigService _siteCfg
@{
    ViewData["Title"] = "Parceira AudioCodes";
    var produtos = _prodSvc.Todos.Where(p => p.Marca == "AudioCodes").ToList();
    var wa = "5519997573053";
}

<!-- ═══ HERO ═══ -->
<section class="relative overflow-hidden min-h-[300px] sm:min-h-[520px] flex items-center" style="background: linear-gradient(135deg, #00205B 0%, #042C71 60%, #0a1a3a 100%);">
    <div class="absolute inset-0" style="background-image:radial-gradient(circle at 70% 40%, rgba(0,120,100,0.2) 0%, transparent 55%)"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-20 w-full grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
            <div class="flex items-center gap-3 mb-6">
                <span class="bg-white/10 border border-white/20 text-white/70 text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full">Parceira Oficial</span>
                <span class="bg-smv-accent text-white text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full">Authorized Reseller</span>
            </div>
            <h1 class="text-3xl sm:text-5xl font-black mb-4 tracking-tight text-white">
                AudioCodes
                <span class="block text-2xl sm:text-3xl font-semibold text-white/50 mt-1">Voice &amp; Network</span>
            </h1>
            <p class="text-white/70 text-lg leading-relaxed mb-8 max-w-lg">
                Infraestrutura de voz, Direct Routing para Microsoft Teams e telefones IP certificados. A SMV Telecom é parceira oficial AudioCodes no Brasil.
            </p>
            <div class="flex flex-wrap gap-3">
                <a href="/#contato"
                   class="bg-smv-accent hover:bg-smv-accentDark text-white font-bold px-7 py-3.5 rounded-full transition-colors inline-flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    Solicitar Proposta
                </a>
                <a href="/Solucoes/Telefones"
                   class="bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold px-7 py-3.5 rounded-full transition-colors">
                    Ver Telefones IP
                </a>
            </div>
        </div>
        <div class="flex items-center justify-center lg:justify-end">
            <div class="relative">
                <div class="absolute -inset-8 bg-teal-500/10 rounded-full blur-3xl"></div>
                <img src="/images/produtos/c470hd.webp" alt="AudioCodes C470HD"
                     class="relative w-full max-w-xs lg:max-w-sm object-contain drop-shadow-2xl"
                     onerror="this.src='/images/produtos/ccx700.webp'" />
            </div>
        </div>
    </div>
</section>

<!-- ═══ STATS ═══ -->
<div class="bg-smv-primary text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
            <p class="text-3xl font-black text-smv-accent">+14</p>
            <p class="text-white/60 text-sm mt-0.5">Modelos de telefone</p>
        </div>
        <div>
            <p class="text-3xl font-black text-smv-accent">SBC</p>
            <p class="text-white/60 text-sm mt-0.5">Session Border Controllers</p>
        </div>
        <div>
            <p class="text-3xl font-black text-smv-accent">MS</p>
            <p class="text-white/60 text-sm mt-0.5">Teams Certified</p>
        </div>
        <div>
            <p class="text-3xl font-black text-smv-accent">PSTN</p>
            <p class="text-white/60 text-sm mt-0.5">Integração Direct Routing</p>
        </div>
    </div>
</div>

<!-- ═══ SOBRE ═══ -->
<section class="py-12 lg:py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div class="order-2 lg:order-1">
            <!-- bloco de destaque Direct Routing -->
            <div class="bg-smv-bg rounded-2xl p-6 border border-gray-100 mb-6">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-smv-primary rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-bold text-smv-text">Direct Routing Microsoft Teams</p>
                        <p class="text-smv-gray text-sm mt-1 leading-relaxed">Os Session Border Controllers (SBC) AudioCodes são a solução mais adotada para habilitar chamadas PSTN diretamente no Microsoft Teams, sem a necessidade de plano de chamadas da Microsoft.</p>
                    </div>
                </div>
            </div>

            <!-- grade de capacidades -->
            <div class="grid grid-cols-2 gap-4">
                @foreach (var item in new[] {
                    new { icon = "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10", title = "Gateways de Voz", desc = "Analógicos e digitais para integração com PSTN" },
                    new { icon = "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z", title = "Telefones IP Teams", desc = "Handsets certificados MS Teams Phone" },
                    new { icon = "M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18", title = "Salas de Reunião", desc = "Endpoints certificados para Teams Rooms" },
                    new { icon = "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z", title = "Segurança de Voz", desc = "SBC com proteção e criptografia de chamadas" }
                })
                {
                    <div class="bg-smv-bg rounded-2xl p-4 border border-gray-100">
                        <div class="w-9 h-9 bg-smv-primary rounded-lg flex items-center justify-center mb-3">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@item.icon"/>
                            </svg>
                        </div>
                        <p class="font-bold text-smv-text text-sm">@item.title</p>
                        <p class="text-smv-gray text-xs mt-1 leading-relaxed">@item.desc</p>
                    </div>
                }
            </div>
        </div>

        <div class="order-1 lg:order-2">
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">Por que AudioCodes?</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text mb-6 leading-tight">
                A espinha dorsal da<br/>telefonia corporativa moderna
            </h2>
            <p class="text-smv-gray leading-relaxed mb-6">
                Líder global em infraestrutura de voz, a AudioCodes desenvolve SBCs, gateways e telefones IP utilizados pelas maiores corporações do mundo. Seus produtos são parceiros homologados da Microsoft para Direct Routing no Teams.
            </p>
            <ul class="space-y-3 mb-8">
                @foreach (var item in new[] {
                    "SBCs certificados pela Microsoft para Direct Routing",
                    "Telefones IP para Microsoft Teams e Zoom Phone",
                    "Gateways para integração com sistemas legados",
                    "Linha completa de handsets para todos os perfis",
                    "Instalação e suporte técnico pela SMV Telecom"
                })
                {
                    <li class="flex items-center gap-3">
                        <div class="w-5 h-5 bg-smv-accent rounded-full flex items-center justify-center flex-shrink-0">
                            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                            </svg>
                        </div>
                        <span class="text-smv-gray text-sm">@item</span>
                    </li>
                }
            </ul>
            <div class="flex items-center gap-4 bg-smv-bg rounded-2xl p-4 border border-gray-100">
                <div class="w-12 h-12 bg-smv-primary rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                    </svg>
                </div>
                <div>
                    <p class="font-bold text-smv-text text-sm">Parceira Autorizada AudioCodes</p>
                    <p class="text-smv-gray text-xs">Revenda e suporte técnico oficial no Brasil</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ PRODUTOS ═══ -->
<section class="py-12 lg:py-20 px-4 bg-smv-bg">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">Catálogo</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text">Telefones AudioCodes disponíveis</h2>
            <p class="text-smv-gray mt-3">Clique em qualquer produto para ver detalhes, especificações e solicitar orçamento.</p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
            @foreach (var p in produtos)
            {
                <a href="/Produto/@p.Slug"
                   class="group bg-white rounded-2xl border border-gray-100 hover:border-smv-primary/30 hover:shadow-lg transition-all duration-200 overflow-hidden flex flex-col">
                    <div class="bg-smv-bg/60 p-4 flex items-center justify-center h-36">
                        @if (!string.IsNullOrEmpty(p.Img))
                        {
                            <img src="/images/produtos/@p.Img" alt="@p.Nome"
                                 class="max-h-28 max-w-full object-contain group-hover:scale-105 transition-transform duration-200"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                            <div class="hidden w-full h-full items-center justify-center">
                                <svg class="w-10 h-10 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        }
                    </div>
                    <div class="p-3 flex flex-col flex-1">
                        <p class="text-xs text-smv-accent font-semibold uppercase tracking-wide">@p.Categoria</p>
                        <p class="text-smv-text font-semibold text-sm mt-0.5 leading-snug flex-1">@p.Nome</p>
                        <div class="mt-2 flex items-center text-smv-primary text-xs font-semibold group-hover:gap-2 transition-all gap-1">
                            Ver detalhes
                            <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<!-- ═══ CTA ═══ -->
<section class="py-12 lg:py-20 px-4 bg-smv-primary relative overflow-hidden">
    <div class="absolute inset-0" style="background-image:radial-gradient(circle at 20% 50%, rgba(0,120,100,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(206,73,18,0.1) 0%, transparent 40%)"></div>
    <div class="relative max-w-4xl mx-auto text-center text-white">
        <span class="inline-block bg-white/10 border border-white/20 text-white/70 text-xs font-semibold uppercase tracking-widest px-3 py-1.5 rounded-full mb-5">Fale com um especialista</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">Implante Direct Routing<br/>ou renove sua telefonia</h2>
        <p class="text-white/60 text-lg mb-8 max-w-2xl mx-auto">
            Nossa equipe cria o projeto ideal para sua infraestrutura de voz, desde a escolha dos equipamentos até a configuração completa no Microsoft Teams.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
            <a href="https://wa.me/@wa" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1db954] text-white font-bold px-8 py-4 rounded-full transition-colors shadow-lg">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Falar no WhatsApp
            </a>
            <a href="/#contato"
               class="inline-flex items-center gap-2 bg-smv-accent hover:bg-smv-accentDark text-white font-bold px-8 py-4 rounded-full transition-colors">
                Solicitar Proposta
            </a>
        </div>
    </div>
</section>
