<!-- ═══════════════════════════ CONTATO ═══════════════════════════ -->
<section id="contato" class="py-20 px-4 bg-smv-bg scroll-mt-[100px]">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
            <span class="inline-block bg-smv-primary text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4">Contato</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text mb-3">Entre em Contato</h2>
            <p class="text-smv-gray text-lg">Nossa equipe está pronta para atendê-lo</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">

            <!-- Info — card navy -->
            <div class="bg-smv-primary rounded-2xl p-8 flex flex-col justify-between text-white shadow-lg">
                <div>
                    <h3 class="text-2xl font-bold mb-2">Fale com a SMV Telecom</h3>
                    <p class="text-white/70 leading-relaxed mb-8">
                        Estamos prontos para ajudar sua empresa a encontrar a solução de comunicação ideal. Entre em contato por qualquer um dos canais abaixo.
                    </p>
                    <div class="space-y-5">
                        <div class="flex items-center gap-4 bg-white/10 rounded-xl px-5 py-4">
