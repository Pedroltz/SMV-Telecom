@page
@model IndexModel
@{
    ViewData["Title"] = "Soluções em Comunicação Corporativa";
}

<!-- ═══════════════════════════ CARROSSEL HERO ═══════════════════════════ -->
<section
    class="relative overflow-hidden"
    style="height: calc(100vh - 100px); min-height: 480px;"
    x-data="{
        current: 0,
        total: 3,
        timer: null,
        init() { this.timer = setInterval(() => this.next(), 8000); },
        next() { this.current = (this.current + 1) % this.total; },
        prev() { this.current = (this.current - 1 + this.total) % this.total; },
        go(i) { this.current = i; clearInterval(this.timer); this.timer = setInterval(() => this.next(), 8000); }
    }"
    x-init="init()">

    <!-- ── Slide 1 ── -->
    <div class="absolute inset-0 transition-opacity duration-1000 ease-in-out"
         :class="current === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'">
        <div class="absolute inset-0 bg-cover bg-center"
             style="background-image: url('https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1920&q=80')"></div>
        <div class="absolute inset-0 bg-smv-primary/70"></div>
        <div class="relative z-10 flex items-center justify-center h-full text-white px-6">
            <div class="max-w-4xl text-center">
                <span class="inline-block bg-smv-accent text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">Comunicação Corporativa</span>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 drop-shadow-lg">
                    Soluções <strong>Criativas</strong> e <strong>Econômicas</strong><br class="hidden sm:block" /> para sua Empresa
                </h1>
                <p class="text-lg sm:text-xl text-white/85 max-w-2xl mx-auto mb-10 leading-relaxed">
                    Especialistas em videoconferência, áudio profissional, telefonia IP e Microsoft Teams para ambientes corporativos de alta performance.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="#contato"
                       class="bg-white hover:bg-smv-bg text-smv-primary font-bold px-10 py-4 rounded-full transition-colors shadow-xl">
                        Fale Conosco
                    </a>
                    <a href="/Solucoes/Videoconferencia"
                       class="bg-white/15 backdrop-blur-sm hover:bg-white/25 border border-white/40 text-white font-semibold px-10 py-4 rounded-full transition-colors">
                        Ver Soluções
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Slide 2 ── -->
    <div class="absolute inset-0 transition-opacity duration-1000 ease-in-out"
         :class="current === 1 ? 'opacity-100 z-10' : 'opacity-0 z-0'">
        <div class="absolute inset-0 bg-cover bg-center"
             style="background-image: url('https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=1920&q=80')"></div>
        <div class="absolute inset-0 bg-smv-primary/65"></div>
        <div class="relative z-10 flex items-center justify-center h-full text-white px-6">
            <div class="max-w-4xl text-center">
                <span class="inline-block bg-smv-accent text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">Videoconferência</span>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 drop-shadow-lg">
                    Conecte Equipes com<br class="hidden sm:block" /> <strong>Qualidade de Alto Nível</strong>
                </h1>
                <p class="text-lg sm:text-xl text-white/85 max-w-2xl mx-auto mb-10 leading-relaxed">
                    Salas de reunião inteligentes com câmeras 4K, microfones array e displays interativos certificados para Microsoft Teams, Zoom e Google Meet.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/Solucoes/Videoconferencia"
                       class="bg-white hover:bg-smv-bg text-smv-primary font-bold px-10 py-4 rounded-full transition-colors shadow-xl">
                        Saiba Mais
                    </a>
                    <a href="#contato"
                       class="bg-white/15 backdrop-blur-sm hover:bg-white/25 border border-white/40 text-white font-semibold px-10 py-4 rounded-full transition-colors">
                        Solicitar Demonstração
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Slide 3 ── -->
    <div class="absolute inset-0 transition-opacity duration-1000 ease-in-out"
         :class="current === 2 ? 'opacity-100 z-10' : 'opacity-0 z-0'">
        <div class="absolute inset-0 bg-cover bg-center"
             style="background-image: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=1920&q=80')"></div>
        <div class="absolute inset-0 bg-smv-primary/70"></div>
        <div class="relative z-10 flex items-center justify-center h-full text-white px-6">
            <div class="max-w-4xl text-center">
                <span class="inline-block bg-smv-accent text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6">Microsoft Teams</span>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 drop-shadow-lg">
                    Especialistas em<br class="hidden sm:block" /> <strong>Microsoft Teams Rooms</strong>
                </h1>
                <p class="text-lg sm:text-xl text-white/85 max-w-2xl mx-auto mb-10 leading-relaxed">
                    Implementação completa do ecossistema Teams com hardware certificado, Direct Routing e suporte especializado para sua empresa.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/Solucoes/MicrosoftTeams"
                       class="bg-white hover:bg-smv-bg text-smv-primary font-bold px-10 py-4 rounded-full transition-colors shadow-xl">
                        Conhecer Solução
                    </a>
                    <a href="#contato"
                       class="bg-white/15 backdrop-blur-sm hover:bg-white/25 border border-white/40 text-white font-semibold px-10 py-4 rounded-full transition-colors">
                        Falar com Especialista
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Seta esquerda ── -->
    <button @@click="prev()"
            class="absolute left-4 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full bg-white/15 backdrop-blur-sm hover:bg-white/30 border border-white/30 text-white transition-colors flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
    </button>

    <!-- ── Seta direita ── -->
    <button @@click="next()"
            class="absolute right-4 top-1/2 -translate-y-1/2 z-20 w-11 h-11 rounded-full bg-white/15 backdrop-blur-sm hover:bg-white/30 border border-white/30 text-white transition-colors flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
    </button>

    <!-- ── Dots ── -->
    <div class="absolute bottom-7 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2.5">
        <template x-for="i in total" :key="i">
            <button @@click="go(i - 1)"
                    class="rounded-full transition-all duration-300"
                    :class="current === i - 1 ? 'w-8 h-2.5 bg-smv-accent' : 'w-2.5 h-2.5 bg-white/50 hover:bg-white/80'">
            </button>
        </template>
    </div>

</section>

<!-- ═══════════════════════════ SOBRE A EMPRESA ═══════════════════════════ -->
<section class="py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-16">

        <!-- Texto -->
        <div class="flex-1 lg:max-w-xl">
            <span class="inline-block bg-smv-primary text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-5">
                Sobre a SMV Telecom
            </span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text leading-tight mb-5">
                Soluções <strong>criativas e econômicas</strong><br />para a sua empresa
            </h2>
            <p class="text-smv-gray leading-relaxed mb-4">
                Sediada em Campinas, SP, a SMV Telecom nasceu com o propósito de ser uma empresa indispensável, merecedora de confiança pelo comprometimento com a transparência e a satisfação do cliente.
            </p>
            <p class="text-smv-gray leading-relaxed mb-8">
                Nossa equipe é formada por profissionais com mais de 20 anos de experiência nos setores de TI e Telecom, especializados em identificar oportunidades de eficiência, redução de custos e geração de retorno sobre investimento para cada cliente.
            </p>

            <!-- Pilares -->
            <div class="space-y-4 mb-8">
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 bg-smv-primary rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-smv-text">Confiança e Transparência</p>
                        <p class="text-smv-gray text-sm mt-0.5">Construímos relacionamentos duradouros baseados em honestidade e comprometimento com os resultados do cliente.</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 bg-smv-primary rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-smv-text">Soluções Inovadoras</p>
                        <p class="text-smv-gray text-sm mt-0.5">Oferecemos valor único por meio de soluções criativas em comunicação que transformam a forma como sua empresa opera.</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <div class="w-10 h-10 bg-smv-primary rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-smv-text">Foco em ROI</p>
                        <p class="text-smv-gray text-sm mt-0.5">Análise técnica e consultoria especializada para maximizar o retorno sobre cada investimento em tecnologia.</p>
                    </div>
                </div>
            </div>

            <a href="/QuemSomos"
               class="inline-flex items-center gap-2 bg-smv-primary hover:bg-smv-dark text-white font-semibold px-8 py-3.5 rounded-full transition-colors">
                Conheça nossa história
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>

        <!-- Imagens -->
        <div class="flex-1 flex justify-center lg:justify-end">
            <div class="relative w-full max-w-lg">
                <!-- Imagem principal -->
                <div class="rounded-2xl overflow-hidden shadow-xl">
                    <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=800&q=80"
                         alt="Equipe SMV Telecom em reunião"
                         class="w-full h-72 object-cover" />
                </div>
                <!-- Imagem secundária (sobreposta) -->
                <div class="absolute -bottom-6 -left-6 w-52 rounded-xl overflow-hidden shadow-2xl border-4 border-white">
                    <img src="https://smvtelecom.com/wp-content/uploads/2024/04/quemsomos-removebg-preview.png"
                         alt="Equipe SMV Telecom"
                         class="w-full h-40 object-contain bg-smv-bg" />
