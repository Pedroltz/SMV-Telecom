@page "/admin/painel"
@model SMVTelecom.Pages.Admin.PainelModel
@{
    Layout = null;
    var cfg = Model.Config;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Painel Admin — SMV Telecom</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script>
        tailwind.config = {
            theme: { extend: { colors: {
                primary: '#042C71',
                dark:    '#021d4d',
                accent:  '#CE4912',
            }}}
        }
    </script>
</head>
<body class="bg-slate-100 min-h-screen" x-data="{ tab: 'config' }">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-60 bg-primary flex flex-col flex-shrink-0 sticky top-0 h-screen">
        <div class="p-6 border-b border-white/10">
            <img src="/images/NovaLogo.png" alt="SMV Telecom" class="h-9 mb-1" />
            <p class="text-white/40 text-xs">Painel Administrativo</p>
        </div>
        <nav class="flex-1 p-4 space-y-1">
            <button @@click="tab='config'"
                    :class="tab==='config' ? 'bg-white/15 text-white' : 'text-white/60 hover:bg-white/10 hover:text-white'"
                    class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors text-left">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                Configurações
            </button>
            <button @@click="tab='produtos'"
                    :class="tab==='produtos' ? 'bg-white/15 text-white' : 'text-white/60 hover:bg-white/10 hover:text-white'"
                    class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors text-left">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
                Produtos
            </button>
            <button @@click="tab='usuarios'"
                    :class="tab==='usuarios' ? 'bg-white/15 text-white' : 'text-white/60 hover:bg-white/10 hover:text-white'"
                    class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors text-left">
                <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                </svg>
                Usuários
            </button>
        </nav>
        <div class="p-4 border-t border-white/10">
            <form method="post" asp-page-handler="Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm text-white/50 hover:bg-white/10 hover:text-white transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Sair
                </button>
            </form>
        </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 p-8 overflow-y-auto">

        <!-- Mensagem global -->
        @if (Model.Mensagem is not null)
        {
        <div class="mb-6 px-4 py-3 rounded-lg text-sm font-medium @(Model.MensagemTipo == "ok" ? "bg-green-50 border border-green-200 text-green-700" : "bg-red-50 border border-red-200 text-red-700")">
            @Model.Mensagem
        </div>
        }

        <!-- ═══ CONFIGURAÇÕES ═══ -->
        <section x-show="tab==='config'" x-cloak>
            <h2 class="text-xl font-bold text-slate-800 mb-6">Configurações do Site</h2>
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 max-w-lg">
                <form method="post" asp-page-handler="SalvarConfig" class="space-y-5">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-1.5">Telefone (exibição)</label>
                        <input name="telefone" value="@cfg.Telefone" required
                               class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                        <p class="text-xs text-slate-400 mt-1">Aparece no header e no rodapé do site.</p>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-1.5">Número WhatsApp (somente dígitos)</label>
                        <input name="whatsapp" value="@cfg.Whatsapp" required
                               class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                        <p class="text-xs text-slate-400 mt-1">Ex: 5511985152865 — usado nos links wa.me/...</p>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-600 uppercase tracking-wider mb-1.5">E-mail de contato</label>
                        <input name="email" type="email" value="@cfg.Email" required
                               class="w-full border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
                    </div>
                    <button type="submit" class="bg-primary hover:bg-dark text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition">
                        Salvar Configurações
                    </button>
                </form>
            </div>
        </section>

        <!-- ═══ PRODUTOS ═══ -->
        <section x-show="tab==='produtos'" x-cloak x-data="{ mostrarForm: false, busca: '', editando: null }">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold text-slate-800">Produtos (@Model.Todos.Count)</h2>
                <button @@click="mostrarForm = !mostrarForm; editando = null"
                        class="bg-accent hover:bg-orange-700 text-white font-semibold px-5 py-2 rounded-lg text-sm transition flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Novo Produto
                </button>
            </div>

            <!-- Formulário novo produto -->
            <div x-show="mostrarForm" x-cloak class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 mb-6">
                <h3 class="font-bold text-slate-700 mb-5">Adicionar Novo Produto</h3>
                <form method="post" asp-page-handler="AdicionarProduto" enctype="multipart/form-data" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="label">Nome *</label>
                        <input name="nome" required class="input" />
                    </div>
                    <div>
                        <label class="label">Slug (URL) *</label>
                        <input name="slug" required placeholder="ex: meu-produto-novo" class="input" />
                        <p class="text-xs text-slate-400 mt-1">Letras minúsculas e hífens. Deve ser único.</p>
                    </div>
                    <div>
                        <label class="label">Marca *</label>
                        <input name="marca" required placeholder="ex: Logitech" class="input" />
                    </div>
                    <div>
                        <label class="label">Categoria *</label>
                        <select name="categoria" required class="input">
                            <option value="Videoconferência">Videoconferência</option>
                            <option value="Áudio">Áudio</option>
                            <option value="Telefones">Telefones</option>
                        </select>
                    </div>
                    <div x-data="{ nomeArquivo: '' }">
                        <label class="label">Imagem do Produto</label>
                        <label class="flex items-center gap-2 cursor-pointer border border-slate-200 rounded-lg px-4 py-2.5 text-sm hover:border-primary transition bg-white">
                            <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span x-text="nomeArquivo || 'Escolher arquivo...'" :class="nomeArquivo ? 'text-slate-700' : 'text-slate-400'" class="truncate"></span>
                            <input type="file" name="imgFile" accept="image/*" class="hidden"
                                   @@change="nomeArquivo = $event.target.files[0]?.name ?? ''; $refs.imgNomeAdicionar.value = nomeArquivo" />
                        </label>
                        <p class="text-xs text-slate-400 mt-1">Ou informe o nome manualmente abaixo (arquivo já em wwwroot/images/produtos/)</p>
                        <input name="img" x-ref="imgNomeAdicionar" placeholder="ex: meu-produto.webp" class="input mt-1.5" />
                    </div>
                    <div class="sm:col-span-2">
                        <label class="label">Descrição Curta *</label>
                        <input name="descricao" required class="input" />
                    </div>
                    <div class="sm:col-span-2">
                        <label class="label">Descrição Longa</label>
                        <textarea name="descricaoLonga" rows="4" class="input resize-y" placeholder="Parágrafos separados por linha em branco..."></textarea>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="label">Características (uma por linha)</label>
                        <textarea name="features" rows="4" class="input resize-y" placeholder="Resolução 4K&#10;Zoom óptico 12x&#10;..."></textarea>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="label">Produtos Relacionados (slugs, um por linha)</label>
                        <textarea name="relacionados" rows="3" class="input resize-y" placeholder="rally-bar&#10;logitech-rally&#10;..."></textarea>
                    </div>
                    <div class="sm:col-span-2 flex gap-3">
                        <button type="submit" class="bg-primary hover:bg-dark text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition">
                            Adicionar Produto
                        </button>
                        <button type="button" @@click="mostrarForm=false" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold px-5 py-2.5 rounded-lg text-sm transition">
                            Cancelar
                        </button>
                    </div>
                </form>
            </div>

            <!-- Formulário editar produto -->
            <div x-show="editando !== null" x-cloak class="bg-white rounded-2xl shadow-sm border border-blue-200 p-6 mb-6">
                <h3 class="font-bold text-slate-700 mb-1">Editar Produto</h3>
                <p class="text-xs text-slate-400 mb-5">Slug: <span x-text="editando?.slug" class="font-mono"></span></p>
                <form method="post" asp-page-handler="EditarProduto" enctype="multipart/form-data" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="slug" :value="editando?.slug" />
                    <div>
                        <label class="label">Nome *</label>
                        <input name="nome" required class="input" x-model="editando.nome" />
                    </div>
                    <div>
                        <label class="label">Marca *</label>
                        <input name="marca" required class="input" x-model="editando.marca" />
                    </div>
                    <div>
                        <label class="label">Categoria *</label>
                        <select name="categoria" required class="input" x-model="editando.categoria">
                            <option value="Videoconferência">Videoconferência</option>
                            <option value="Áudio">Áudio</option>
                            <option value="Telefones">Telefones</option>
                        </select>
                    </div>
                    <div x-data="{ nomeArquivo: '' }">
                        <label class="label">Imagem do Produto</label>
                        <label class="flex items-center gap-2 cursor-pointer border border-slate-200 rounded-lg px-4 py-2.5 text-sm hover:border-primary transition bg-white">
                            <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            <span x-text="nomeArquivo || 'Escolher novo arquivo...'" :class="nomeArquivo ? 'text-slate-700' : 'text-slate-400'" class="truncate"></span>
                            <input type="file" name="imgFile" accept="image/*" class="hidden"
                                   @@change="nomeArquivo = $event.target.files[0]?.name ?? ''; editando.img = nomeArquivo" />
                        </label>
                        <p class="text-xs text-slate-400 mt-1">Deixe em branco para manter a imagem atual</p>
                        <input name="img" class="input mt-1.5" x-model="editando.img" placeholder="nome-do-arquivo.webp" />
                    </div>
                    <div class="sm:col-span-2">
                        <label class="label">Descrição Curta *</label>
                        <input name="descricao" required class="input" x-model="editando.descricao" />
                    </div>
                    <div class="sm:col-span-2">
                        <label class="label">Descrição Longa</label>
                        <textarea name="descricaoLonga" rows="4" class="input resize-y" x-model="editando.descricaoLonga"></textarea>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="label">Características (uma por linha)</label>
                        <textarea name="features" rows="4" class="input resize-y" x-model="editando.features"></textarea>
                    </div>
                    <div class="sm:col-span-2">
                        <label class="label">Produtos Relacionados (slugs, um por linha)</label>
                        <textarea name="relacionados" rows="3" class="input resize-y" x-model="editando.relacionados"></textarea>
                    </div>
                    <div class="sm:col-span-2 flex gap-3">
                        <button type="submit" class="bg-primary hover:bg-dark text-white font-semibold px-6 py-2.5 rounded-lg text-sm transition">
                            Salvar Alterações
                        </button>
                        <button type="button" @@click="editando=null" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold px-5 py-2.5 rounded-lg text-sm transition">
                            Cancelar
                        </button>
                    </div>
                </form>
            </div>

            <!-- Busca -->
            <div class="mb-4">
                <input x-model="busca" placeholder="Buscar produto por nome ou marca..."
                       class="w-full max-w-sm border border-slate-200 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition" />
            </div>

            <!-- Tabela -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-slate-100 bg-slate-50 text-xs font-bold text-slate-500 uppercase tracking-wider">
                            <th class="px-5 py-3 text-left">Nome</th>
                            <th class="px-5 py-3 text-left">Marca</th>
                            <th class="px-5 py-3 text-left">Categoria</th>
                            <th class="px-5 py-3 text-left">Tipo</th>
                            <th class="px-5 py-3"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prod in Model.Todos)
                        {
                        var prodJson = System.Text.Json.JsonSerializer.Serialize(new {
                            slug         = prod.Slug,
                            nome         = prod.Nome,
                            marca        = prod.Marca,
                            categoria    = prod.Categoria,
                            img          = prod.Img ?? "",
                            descricao    = prod.Descricao,
                            descricaoLonga = prod.DescricaoLonga ?? "",
                            features     = string.Join("\n", prod.Features     ?? Array.Empty<string>()),
                            relacionados = string.Join("\n", prod.Relacionados ?? Array.Empty<string>())
                        });
                        <tr class="border-b border-slate-50 hover:bg-slate-50 transition"
                            x-show="busca==='' || '@prod.Nome.ToLower()'.includes(busca.toLowerCase()) || '@prod.Marca.ToLower()'.includes(busca.toLowerCase())">
                            <td class="px-5 py-3 font-medium text-slate-800">@prod.Nome</td>
                            <td class="px-5 py-3 text-slate-500">@prod.Marca</td>
                            <td class="px-5 py-3">
                                <span class="inline-block text-xs px-2 py-0.5 rounded-full font-medium
                                    @(prod.Categoria == "Videoconferência" ? "bg-blue-50 text-blue-700" :
                                      prod.Categoria == "Áudio"           ? "bg-purple-50 text-purple-700" :
                                                                            "bg-green-50 text-green-700")">
                                    @prod.Categoria
                                </span>
                            </td>
                            <td class="px-5 py-3">
                                @if (!Model.IsExtra(prod.Slug))
                                {
                                <span class="text-xs text-slate-400">Estático</span>
                                }
                                else
                                {
                                <span class="text-xs text-orange-600 font-medium">Customizado</span>
                                }
                            </td>
                            <td class="px-5 py-3 text-right">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/Produto/@prod.Slug" target="_blank"
                                       class="text-xs text-primary hover:underline">Ver</a>
                                    <button type="button"
                                            data-prod='@Html.Raw(prodJson)'
                                            @@click="editando = JSON.parse($el.dataset.prod); mostrarForm = false; $nextTick(() => $el.closest('section').querySelector('[x-show]').scrollIntoView({behavior:'smooth'}))"
                                            class="text-xs text-blue-500 hover:text-blue-700 transition">Editar</button>
                                    <form method="post" asp-page-handler="RemoverProduto"
                                          onsubmit="return confirm('Remover @prod.Nome.Replace("'", "\\'")?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="slugRemover" value="@prod.Slug" />
                                        <button type="submit" class="text-xs text-red-500 hover:text-red-700 transition">Remover</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <!-- ═══ USUÁRIOS ═══ -->
        <section x-show="tab==='usuarios'" x-cloak>
            <h2 class="text-xl font-bold text-slate-800 mb-6">Usuários Administradores</h2>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

                <!-- Lista de usuários -->
                <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                    <h3 class="font-bold text-slate-700 mb-4">Usuários Ativos</h3>
                    <ul class="space-y-2 mb-6">
                        @foreach (var email in Model.Users)
                        {
                        <li class="flex items-center justify-between py-2 border-b border-slate-50 last:border-0">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center">
                                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                    </svg>
                                </div>
                                <span class="text-sm text-slate-700">@email</span>
                            </div>
                            @if (Model.Users.Count > 1)
                            {
                            <form method="post" asp-page-handler="RemoverUsuario"
                                  onsubmit="return confirm('Remover @email?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="emailRemover" value="@email" />
                                <button type="submit" class="text-xs text-red-400 hover:text-red-600 transition">Remover</button>
                            </form>
                            }
                        </li>
                        }
                    </ul>
                </div>

                <!-- Formulários -->
                <div class="space-y-4">
                    <!-- Adicionar usuário -->
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                        <h3 class="font-bold text-slate-700 mb-4">Adicionar Usuário</h3>
                        <form method="post" asp-page-handler="AdicionarUsuario" class="space-y-3">
                            @Html.AntiForgeryToken()
                            <input name="novoEmail" type="email" placeholder="E-mail" required class="input" />
                            <input name="novaSenha" type="password" placeholder="Senha" required class="input" />
                            <button type="submit" class="bg-primary hover:bg-dark text-white font-semibold px-5 py-2 rounded-lg text-sm transition w-full">
                                Criar Usuário
                            </button>
                        </form>
                    </div>
                    <!-- Alterar senha -->
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
                        <h3 class="font-bold text-slate-700 mb-4">Alterar Senha</h3>
                        <form method="post" asp-page-handler="AlterarSenha" class="space-y-3">
                            @Html.AntiForgeryToken()
                            <select name="emailAlterarSenha" required class="input">
                                @foreach (var email in Model.Users)
                                {<option value="@email">@email</option>}
                            </select>
                            <input name="novaSenhaAlterada" type="password" placeholder="Nova senha" required class="input" />
                            <button type="submit" class="bg-primary hover:bg-dark text-white font-semibold px-5 py-2 rounded-lg text-sm transition w-full">
                                Alterar Senha
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>

    </main>
</div>

<style>
    [x-cloak] { display: none !important; }
