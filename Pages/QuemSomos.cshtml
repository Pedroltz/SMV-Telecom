@page
@model SMVTelecom.Pages.QuemSomosModel
@{
    ViewData["Title"] = "Quem Somos";
}

<!-- ═══ HERO ═══ -->
<section class="hero-gradient text-white py-12 sm:py-20 px-4">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 items-center">
        <div>
            <span class="inline-block bg-white/15 text-white/80 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-5">Sobre a SMV Telecom</span>
            <h1 class="text-2xl sm:text-4xl font-black tracking-tight leading-tight mb-5">
                Especialistas em<br/>comunicação corporativa
            </h1>
            <p class="text-white/65 text-lg leading-relaxed max-w-lg">
                Há mais de 15 anos levamos soluções de videoconferência, áudio, telefonia IP e Microsoft Teams para empresas de todos os portes — com consultoria, instalação e suporte técnico especializado.
            </p>
        </div>
        <div class="flex justify-center lg:justify-end">
            <img src="/images/equipe-transparente.png"
                 alt="Equipe SMV Telecom"
                 class="w-full max-w-md sm:max-w-xl object-contain drop-shadow-xl" />
        </div>
    </div>
</section>


<!-- ═══ NOSSA HISTÓRIA ═══ -->
<section class="py-12 lg:py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div>
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">Nossa História</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text mb-6 leading-tight">
                Mais de 15 anos<br/>conectando empresas
            </h2>
            <div class="space-y-4 text-smv-gray leading-relaxed">
                <p>
                    A SMV Telecom nasceu com uma missão clara: levar comunicação corporativa de alta performance para empresas brasileiras de todos os tamanhos. Desde o início, nosso foco foi entregar não apenas equipamentos, mas soluções completas — do diagnóstico à implantação e ao suporte contínuo.
                </p>
                <p>
                    Ao longo de mais de 15 anos, acumulamos experiência em quatro grandes pilares: <strong class="text-smv-text">videoconferência</strong>, <strong class="text-smv-text">áudio profissional</strong>, <strong class="text-smv-text">telefonia IP</strong> e o ecossistema <strong class="text-smv-text">Microsoft Teams</strong>. Cada projeto reforçou nosso compromisso com a excelência técnica e a satisfação dos clientes.
                </p>
                <p>
                    Hoje somos parceiros autorizados das principais marcas do mercado global — Logitech e Poly/HP, além de sermos importadores diretos e distribuidores das soluções AudioCodes — entregando projetos em empresas de médio e grande porte em todo o Brasil.
                </p>
            </div>
        </div>

        <!-- linha do tempo -->
        <div class="relative pl-8 border-l-2 border-gray-100 space-y-8">
            @foreach (var item in new[] {
                new { ano="Fundação", titulo="SMV Telecom é criada", desc="Início das operações com foco em soluções de telefonia e comunicação corporativa para empresas paulistas." },
                new { ano="Crescimento", titulo="Expansão para videoconferência", desc="Ampliamos o portfólio com soluções de videoconferência, atendendo empresas que buscavam salas de reunião de alta qualidade." },
                new { ano="Parceiros", titulo="Parcerias globais firmadas", desc="Tornamo-nos parceiros autorizados Logitech, AudioCodes e Poly/HP, ampliando o acesso a hardware premium certificado." },
                new { ano="Hoje", titulo="Especialistas em Microsoft Teams", desc="Referência em implementação de Microsoft Teams Phone, Direct Routing e Teams Rooms para o mercado corporativo brasileiro." },
            })
            {
                <div class="relative">
                    <div class="absolute -left-[41px] w-4 h-4 rounded-full bg-smv-accent border-2 border-white shadow"></div>
                    <span class="text-[11px] font-bold text-smv-accent uppercase tracking-widest">@item.ano</span>
                    <h3 class="font-bold text-smv-text mt-0.5 mb-1">@item.titulo</h3>
                    <p class="text-smv-gray text-sm leading-relaxed">@item.desc</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- ═══ MISSÃO / VISÃO / VALORES ═══ -->
<section class="py-12 lg:py-20 px-4 bg-smv-bg">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">O que nos guia</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text">Missão, Visão e Valores</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Missão -->
            <div class="bg-smv-primary text-white rounded-2xl p-8">
                <div class="w-12 h-12 bg-white/15 rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <h3 class="font-bold text-lg mb-3">Missão</h3>
                <p class="text-white/70 leading-relaxed text-sm">
                    Entregar soluções de comunicação corporativa que transformam a forma como as empresas colaboram — com tecnologia de ponta, suporte especializado e foco total no sucesso do cliente.
                </p>
            </div>
            <!-- Visão -->
            <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm">
                <div class="w-12 h-12 bg-smv-bg rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-smv-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </div>
                <h3 class="font-bold text-lg text-smv-text mb-3">Visão</h3>
                <p class="text-smv-gray leading-relaxed text-sm">
                    Ser referência nacional em soluções de comunicação unificada, reconhecida pela excelência técnica, agilidade no atendimento e pelos resultados concretos entregues aos nossos clientes.
                </p>
            </div>
            <!-- Valores -->
            <div class="bg-smv-accent text-white rounded-2xl p-8">
                <div class="w-12 h-12 bg-white/15 rounded-xl flex items-center justify-center mb-5">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                </div>
                <h3 class="font-bold text-lg mb-3">Valores</h3>
                <ul class="space-y-2 text-white/80 text-sm">
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-white/60 rounded-full flex-shrink-0"></span>Excelência técnica</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-white/60 rounded-full flex-shrink-0"></span>Compromisso com o cliente</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-white/60 rounded-full flex-shrink-0"></span>Transparência e ética</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-white/60 rounded-full flex-shrink-0"></span>Inovação contínua</li>
                    <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-white/60 rounded-full flex-shrink-0"></span>Parceria de longo prazo</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- ═══ O QUE FAZEMOS ═══ -->
<section class="py-12 lg:py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">Atuação</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text">O que fazemos</h2>
            <p class="text-smv-gray mt-3 max-w-xl mx-auto">Da consultoria à instalação — entregamos projetos completos nas quatro principais áreas de comunicação corporativa.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @foreach (var area in new[] {
                new { icon="M15 10l4.553-2.069A1 1 0 0121 8.82v6.362a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z", titulo="Videoconferência", desc="Câmeras 4K, barras de vídeo all-in-one e sistemas de sala certificados Teams, Zoom e Meet para salas de qualquer tamanho.", link="/Solucoes/Videoconferencia" },
                new { icon="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z", titulo="Áudio Profissional", desc="Speakerphones omnidirecionais, headsets com ANC e microfones para home office, salas pequenas e ambientes maiores.", link="/Solucoes/Audio" },
                new { icon="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z", titulo="Telefonia IP", desc="Handsets certificados Microsoft Teams com PoE, tela touchscreen e integração nativa ao Direct Routing e SBCs AudioCodes.", link="/Solucoes/Telefones" },
                new { icon="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z", titulo="Microsoft Teams", desc="Implementação completa do Teams Phone, Direct Routing, Teams Rooms e consultoria Microsoft 365 para empresas.", link="/Solucoes/MicrosoftTeams" },
            })
            {
                <a href="@area.link" class="group block bg-smv-bg rounded-2xl p-7 border border-gray-100 hover:border-smv-primary/20 hover:shadow-md transition-all duration-200">
                    <div class="w-12 h-12 bg-smv-primary rounded-xl flex items-center justify-center mb-5 group-hover:bg-smv-accent transition-colors duration-200">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@area.icon"/>
                        </svg>
                    </div>
                    <h3 class="font-bold text-smv-text text-base mb-2">@area.titulo</h3>
                    <p class="text-smv-gray text-sm leading-relaxed mb-4">@area.desc</p>
                    <span class="text-smv-primary text-xs font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
                        Saiba mais
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </span>
                </a>
            }
        </div>
    </div>
</section>

<!-- ═══ PARCEIRAS ═══ -->
<section class="py-12 lg:py-20 px-4 bg-smv-bg">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">Parceiras Oficiais</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text">Marcas que representamos</h2>
            <p class="text-smv-gray mt-3">Somos revendedores autorizados das três principais marcas de comunicação corporativa do mercado global.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <a href="/Parceiras/Logitech"
               class="group bg-white rounded-2xl p-8 border border-gray-100 hover:border-smv-primary/20 hover:shadow-md transition-all duration-200 flex flex-col">
                <div class="text-2xl font-black text-smv-text mb-1 group-hover:text-smv-primary transition-colors">Logitech</div>
                <div class="text-xs text-smv-accent font-bold uppercase tracking-widest mb-4">for Business</div>
                <p class="text-smv-gray text-sm leading-relaxed flex-1">
                    Líder global em câmeras, barras de vídeo e headsets para salas de reunião. Certificação nativa para Microsoft Teams, Zoom e Google Meet.
                </p>
                <div class="mt-5 flex flex-wrap gap-2">
                    @foreach (var t in new[]{ "Rally Bar", "Scribe", "Zone Wireless", "Rally Camera" })
                    {
                        <span class="bg-smv-bg text-smv-primary text-[11px] font-semibold px-2.5 py-1 rounded-full border border-gray-200">@t</span>
                    }
                </div>
                <div class="mt-4 text-smv-primary text-xs font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
                    Ver produtos <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </div>
            </a>

            <a href="/Parceiras/PolyHP"
               class="group bg-white rounded-2xl p-8 border border-gray-100 hover:border-smv-primary/20 hover:shadow-md transition-all duration-200 flex flex-col">
                <div class="text-2xl font-black text-smv-text mb-1 group-hover:text-smv-primary transition-colors">Poly</div>
                <div class="text-xs text-smv-accent font-bold uppercase tracking-widest mb-4">part of HP</div>
                <p class="text-smv-gray text-sm leading-relaxed flex-1">
                    Referência em speakerphones, câmeras PTZ e sistemas de videoconferência para ambientes corporativos de qualquer escala.
                </p>
                <div class="mt-5 flex flex-wrap gap-2">
                    @foreach (var t in new[]{ "Studio X", "Sync 40", "PTZ Pro 2", "G7500" })
                    {
                        <span class="bg-smv-bg text-smv-primary text-[11px] font-semibold px-2.5 py-1 rounded-full border border-gray-200">@t</span>
                    }
                </div>
                <div class="mt-4 text-smv-primary text-xs font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
                    Ver produtos <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </div>
            </a>

            <a href="/Parceiras/AudioCodes"
               class="group bg-white rounded-2xl p-8 border border-gray-100 hover:border-smv-primary/20 hover:shadow-md transition-all duration-200 flex flex-col">
                <div class="text-2xl font-black text-smv-text mb-1 group-hover:text-smv-primary transition-colors">AudioCodes</div>
                <div class="text-xs text-smv-accent font-bold uppercase tracking-widest mb-4">Voice &amp; Network</div>
                <p class="text-smv-gray text-sm leading-relaxed flex-1">
                    Líder em infraestrutura de voz corporativa. SBCs certificados pela Microsoft para Direct Routing, gateways e telefones IP Teams.
                </p>
                <div class="mt-5 flex flex-wrap gap-2">
                    @foreach (var t in new[]{ "C470HD", "C455HD", "SBC", "Direct Routing" })
                    {
                        <span class="bg-smv-bg text-smv-primary text-[11px] font-semibold px-2.5 py-1 rounded-full border border-gray-200">@t</span>
                    }
                </div>
                <div class="mt-4 text-smv-primary text-xs font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
                    Ver produtos <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ═══ POR QUE NÓS ═══ -->
<section class="py-12 lg:py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
        <div>
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">Nossos Diferenciais</span>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-smv-text mb-6 leading-tight">Por que escolher<br/>a SMV Telecom?</h2>
            <p class="text-smv-gray leading-relaxed mb-8">
                Não somos apenas revendedores. Somos consultores técnicos que entendem o ambiente da sua empresa, recomendam a solução certa e acompanham o projeto do início ao fim.
            </p>
            <div class="space-y-4">
                @foreach (var d in new[] {
                    new { titulo="Equipe técnica certificada", desc="Profissionais com certificações nas principais plataformas e marcas do mercado." },
                    new { titulo="Projeto sob medida", desc="Cada solução é desenhada para o tamanho e a necessidade real da sua empresa." },
                    new { titulo="Parceiro, não fornecedor", desc="Construímos relacionamentos de longo prazo com suporte contínuo e presença ativa." },
                    new { titulo="Portfólio completo", desc="Videoconferência, áudio, telefonia e Teams — tudo em um único parceiro de confiança." },
                })
                {
                    <div class="flex items-start gap-4">
                        <div class="w-8 h-8 bg-smv-accent/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                            <div class="w-2.5 h-2.5 bg-smv-accent rounded-full"></div>
                        </div>
                        <div>
                            <p class="font-semibold text-smv-text text-sm">@d.titulo</p>
                            <p class="text-smv-gray text-sm mt-0.5">@d.desc</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="bg-smv-bg rounded-2xl p-8 border border-gray-100 space-y-6">
            @foreach (var d in new[] {
                new { num="+15", label="anos de experiência no mercado" },
                new { num="3",   label="marcas parceiras globais" },
                new { num="4",   label="áreas de atuação" },
            })
            {
                <div class="flex items-center gap-5 pb-6 border-b border-gray-200 last:pb-0 last:border-0">
                    <span class="text-3xl font-black text-smv-primary w-14 shrink-0">@d.num</span>
                    <span class="text-smv-gray text-sm">@d.label</span>
                </div>
            }
        </div>
    </div>
</section>

