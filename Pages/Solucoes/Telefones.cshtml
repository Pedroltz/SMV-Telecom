@page
@model SMVTelecom.Pages.Solucoes.TelefonesModel
@using SMVTelecom.Services
@inject ProdutoService _prodSvc
@inject SiteConfigService _siteCfg
@{
    ViewData["Title"] = "Telefones IP";
    var produtos = _prodSvc.GetByCategoria("Telefones");
    var wa = "5519997573053";
}

<!-- ═══ HERO ═══ -->
<section class="hero-gradient text-white py-10 sm:py-16 px-4">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
            <div>
                <div class="flex items-center gap-2 mb-3">
                    <span class="bg-white/15 text-white/80 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full">Soluções</span>
                    <span class="text-white/40 text-xs">·</span>
                    <span class="text-white/60 text-xs">AudioCodes · Direct Routing · Teams Certified</span>
                </div>
                <h1 class="text-2xl sm:text-4xl font-black tracking-tight mb-3">Telefones IP</h1>
                <p class="text-white/60 text-base max-w-xl">
                    Handsets certificados para Microsoft Teams e sistemas VoIP, com PoE, tela touchscreen e integração nativa ao Direct Routing.
                </p>
            </div>
            <a href="/#contato"
               class="inline-flex items-center gap-2 bg-smv-accent hover:bg-smv-accentDark text-white font-bold px-6 py-3 rounded-full transition-colors text-sm shrink-0 self-start sm:self-auto">
                Solicitar Proposta
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>
        </div>
    </div>
</section>

<!-- ═══ DIFERENCIAIS ═══ -->
<div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-wrap gap-x-8 gap-y-3">
        @foreach (var d in new[] {
            new { icon="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", label="Certificação Microsoft Teams" },
            new { icon="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z", label="Direct Routing (SBC)" },
            new { icon="M13 10V3L4 14h7v7l9-11h-7z", label="PoE — sem fonte adicional" },
            new { icon="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", label="Tela touchscreen" },
            new { icon="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z", label="Áudio HD" },
        })
        {
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-smv-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@d.icon"/>
                </svg>
                <span class="text-sm font-medium text-smv-text">@d.label</span>
            </div>
        }
    </div>
</div>

<!-- ═══ PRODUTOS ═══ -->
<section class="py-14 px-4 bg-smv-bg">
    <div class="max-w-7xl mx-auto">
        <div class="flex items-baseline justify-between mb-8">
            <h2 class="text-xl font-bold text-smv-text">@produtos.Count modelos disponíveis</h2>
            <span class="text-smv-gray text-sm hidden sm:block">Clique para ver especificações e solicitar orçamento</span>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
            @foreach (var p in produtos)
            {
                <a href="/Produto/@p.Slug"
                   class="group bg-white rounded-2xl border border-gray-100 hover:border-smv-primary/20 hover:shadow-md transition-all duration-200 overflow-hidden flex flex-col">
                    <div class="p-5 flex items-center justify-center h-36 bg-gray-50/50">
                        @if (!string.IsNullOrEmpty(p.Img))
                        {
                            <img src="/images/produtos/@p.Img" alt="@p.Nome"
                                 class="max-h-28 max-w-full object-contain group-hover:scale-105 transition-transform duration-200"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                            <div class="hidden w-full h-full items-center justify-center">
                                <svg class="w-10 h-10 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                            </div>
                        }
                    </div>
                    <div class="p-4 flex flex-col flex-1 border-t border-gray-50">
                        <p class="text-[11px] text-smv-accent font-bold uppercase tracking-wider mb-1">@p.Marca</p>
                        <p class="text-smv-text font-semibold text-sm leading-snug flex-1">@p.Nome</p>
                        <div class="mt-3 flex items-center justify-between">
                            <span class="text-[11px] text-gray-400">@p.Categoria</span>
                            <svg class="w-4 h-4 text-smv-primary group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<!-- ═══ CTA ═══ -->
<section class="py-14 px-4 bg-white border-t border-gray-100">
    <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
            <h3 class="text-xl font-bold text-smv-text mb-1">Modernize a telefonia da sua empresa</h3>
            <p class="text-smv-gray text-sm">Nossa equipe projeta e implementa o sistema ideal, incluindo Direct Routing e provisionamento.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
            <a href="https://wa.me/@wa" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1db954] text-white font-bold px-5 py-3 rounded-full transition-colors text-sm">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
            </a>
            <a href="/#contato"
               class="inline-flex items-center gap-2 border border-smv-primary text-smv-primary hover:bg-smv-primary hover:text-white font-bold px-5 py-3 rounded-full transition-colors text-sm">
                Solicitar Proposta
            </a>
        </div>
    </div>
</section>
