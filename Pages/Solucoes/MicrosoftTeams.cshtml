@page
@model SMVTelecom.Pages.Solucoes.MicrosoftTeamsModel
@using SMVTelecom.Services
@inject ProdutoService _prodSvc
@inject SiteConfigService _siteCfg
@{
    ViewData["Title"] = "Microsoft Teams";
    var wa = "5519997573053";
    var telefones = _prodSvc.GetByCategoria("Telefones").Take(6).ToList();
}

<!-- ═══ HERO ═══ -->
<section class="hero-gradient text-white py-10 sm:py-16 px-4">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
            <div>
                <div class="flex items-center gap-2 mb-3">
                    <span class="bg-white/15 text-white/80 text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full">Soluções</span>
                    <span class="text-white/40 text-xs">·</span>
                    <span class="text-white/60 text-xs">Voz · Vídeo · Direct Routing · Teams Rooms</span>
                </div>
                <h1 class="text-2xl sm:text-4xl font-black tracking-tight mb-3">Microsoft Teams</h1>
                <p class="text-white/60 text-base max-w-xl">
                    Implementação completa do ecossistema Teams — telefones IP certificados, Teams Rooms, Direct Routing e consultoria Microsoft 365.
                </p>
            </div>
            <a href="/#contato"
               class="inline-flex items-center gap-2 bg-smv-accent hover:bg-smv-accentDark text-white font-bold px-6 py-3 rounded-full transition-colors text-sm shrink-0 self-start sm:self-auto">
                Solicitar Consultoria
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
            </a>
        </div>
    </div>
</section>

<!-- ═══ DIFERENCIAIS ═══ -->
<div class="bg-white border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-wrap gap-x-8 gap-y-3">
        @foreach (var d in new[] {
            new { icon="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z", label="Telefones IP Certificados" },
            new { icon="M15 10l4.553-2.069A1 1 0 0121 8.82v6.362a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z", label="Teams Rooms (MTR)" },
            new { icon="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z", label="Direct Routing SBC" },
            new { icon="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10", label="Gateways PSTN" },
            new { icon="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", label="Consultoria Microsoft 365" },
        })
        {
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-smv-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@d.icon"/>
                </svg>
                <span class="text-sm font-medium text-smv-text">@d.label</span>
            </div>
        }
    </div>
</div>

<!-- ═══ VISÃO GERAL ═══ -->
<section class="py-10 sm:py-16 px-4 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14 items-center">
        <div>
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">Visão Geral</span>
            <h2 class="text-3xl font-extrabold text-smv-text mb-5 leading-tight">Uma fonte unificada para voz, vídeo e colaboração</h2>
            <p class="text-smv-gray leading-relaxed mb-4">
                A SMV Telecom oferece um portfólio completo que simplifica a habilitação de voz no Microsoft Teams — integrando telefones IP, soluções de sala, SBCs e expertise em consultoria para implementações do Microsoft 365.
            </p>
            <p class="text-smv-gray leading-relaxed mb-8">
                Nossas soluções atendem ambientes on-premises e nuvem, com gerenciamento centralizado e cobertura completa para todos os tipos de sala.
            </p>
            <div class="grid grid-cols-2 gap-3">
                @foreach (var item in new[] {
                    "Telefones IP Teams Certified",
                    "Teams Rooms (MTR)",
                    "Direct Routing via SBC",
                    "Consultoria Microsoft 365"
                })
                {
                    <div class="flex items-center gap-2.5 bg-smv-bg rounded-xl px-4 py-3 border border-gray-100">
                        <div class="w-2 h-2 bg-smv-accent rounded-full flex-shrink-0"></div>
                        <span class="text-smv-text text-xs font-semibold">@item</span>
                    </div>
                }
            </div>
        </div>
        <div class="flex justify-center">
            <img src="/images/teams-ecosystem-color.png" alt="Microsoft Teams Ecosystem"
                 class="w-full max-w-md object-contain" />
        </div>
    </div>
</section>

<!-- ═══ DIRECT ROUTING ═══ -->
<section class="py-10 sm:py-16 px-4 bg-smv-bg">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14 items-center">
        <div class="flex justify-center order-2 lg:order-1">
            <img src="/images/teams-direct-routing-alt.png" alt="Direct Routing Microsoft Teams"
                 class="w-full max-w-md object-contain rounded-2xl"
                 onerror="this.src='/images/teams-direct-routing.png'" />
        </div>
        <div class="order-1 lg:order-2">
            <span class="inline-block bg-smv-accent text-white text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4">Direct Routing</span>
            <h2 class="text-3xl font-extrabold text-smv-text mb-5 leading-tight">Conecte o Teams à sua operadora local</h2>
            <p class="text-smv-gray leading-relaxed mb-4">
                O Direct Routing permite que empresas Teams se conectem a provedores PSTN locais via Session Border Controllers (SBCs) certificados pela Microsoft, sem depender do plano de chamadas da Microsoft.
            </p>
            <p class="text-smv-gray leading-relaxed mb-6">
                Suporte a cenários single e multi-tenant. Preserva o investimento existente em infraestrutura de voz enquanto migra gradualmente para o Teams.
            </p>
            <div class="flex flex-wrap gap-2">
                @foreach (var tag in new[]{ "SBC Certificado", "PSTN Local", "SIP Trunk", "Multi-tenant", "Single-tenant" })
                {
                    <span class="bg-white text-smv-primary text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-200">@tag</span>
                }
            </div>
        </div>
    </div>
</section>

<!-- ═══ AUDIOCODES ONE VOICE ═══ -->
<section class="py-10 sm:py-16 px-4 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14 items-start">
        <div>
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">AudioCodes One Voice</span>
            <h2 class="text-3xl font-extrabold text-smv-text mb-5 leading-tight">Portfólio completo para habilitação de voz</h2>
            <p class="text-smv-gray leading-relaxed mb-6">
                O AudioCodes One Voice for Microsoft Teams abrange toda a jornada de habilitação de voz — da consultoria inicial à implantação de telefones, SBCs e gateways, com suporte contínuo.
            </p>
            <a href="/Parceiras/AudioCodes"
               class="inline-flex items-center gap-2 border border-smv-primary text-smv-primary hover:bg-smv-primary hover:text-white font-semibold px-5 py-2.5 rounded-full transition-colors text-sm">
                Conhecer AudioCodes
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>
        <div class="space-y-3">
            @foreach (var item in new[] {
                new { titulo="Telefones IP Certificados", desc="Interface nativa Teams, áudio HD, PoE — do recepcionista ao executivo." },
                new { titulo="Soluções de Sala (MTR)", desc="Barras all-in-one com Android Teams para salas de qualquer porte." },
                new { titulo="Voz Ponta a Ponta", desc="SBCs e gateways para integração PSTN, Direct Routing e SIP Trunk." },
                new { titulo="Consultoria Microsoft 365", desc="Implementação on-premises ou nuvem com suporte técnico dedicado." }
            })
            {
                <div class="flex items-start gap-4 p-4 bg-smv-bg rounded-xl border border-gray-100">
                    <div class="w-8 h-8 bg-smv-primary rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-smv-text text-sm">@item.titulo</p>
                        <p class="text-smv-gray text-xs mt-0.5 leading-relaxed">@item.desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ═══ TELEFONES CERTIFICADOS ═══ -->
<section class="py-10 sm:py-16 px-4 bg-smv-bg">
    <div class="max-w-7xl mx-auto">
        <div class="flex items-baseline justify-between mb-8">
            <div>
                <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-1">Produtos</span>
                <h2 class="text-xl font-bold text-smv-text">Telefones IP Certificados Microsoft Teams</h2>
            </div>
            <a href="/Solucoes/Telefones"
               class="text-smv-primary hover:text-smv-dark text-sm font-semibold flex items-center gap-1 hidden sm:flex">
                Ver todos
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
            @foreach (var p in telefones)
            {
                <a href="/Produto/@p.Slug"
                   class="group bg-white rounded-2xl border border-gray-100 hover:border-smv-primary/20 hover:shadow-md transition-all duration-200 overflow-hidden flex flex-col">
                    <div class="p-4 flex items-center justify-center h-28 bg-gray-50/50">
                        @if (!string.IsNullOrEmpty(p.Img))
                        {
                            <img src="/images/produtos/@p.Img" alt="@p.Nome"
                                 class="max-h-24 max-w-full object-contain group-hover:scale-105 transition-transform duration-200"
                                 onerror="this.style.display='none'" />
                        }
                    </div>
                    <div class="p-3 border-t border-gray-50 flex-1 flex flex-col">
                        <p class="text-smv-text font-semibold text-xs leading-snug flex-1">@p.Nome</p>
                        <div class="mt-2 flex items-center text-smv-primary text-xs font-semibold gap-1">
                            Ver mais
                            <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                        </div>
                    </div>
                </a>
            }
        </div>

        <div class="mt-6 text-center sm:hidden">
            <a href="/Solucoes/Telefones"
               class="inline-flex items-center gap-2 border border-smv-primary text-smv-primary font-semibold px-5 py-2.5 rounded-full text-sm">
                Ver todos os telefones
            </a>
        </div>
    </div>
</section>

<!-- ═══ MEDIA GATEWAYS ═══ -->
<section class="py-10 sm:py-16 px-4 bg-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14 items-center">
        <div>
            <span class="inline-block text-smv-accent font-bold text-xs uppercase tracking-widest mb-3">Media Gateways</span>
            <h2 class="text-3xl font-extrabold text-smv-text mb-5 leading-tight">Conectividade com infraestrutura legada</h2>
            <p class="text-smv-gray leading-relaxed mb-4">
                Os gateways AudioCodes conectam dispositivos analógicos legados, PSTN e aplicações SIP ao Microsoft Teams Direct Routing — sem descartar o investimento existente.
            </p>
            <p class="text-smv-gray leading-relaxed mb-6">
                Migre gradualmente para o ecossistema Teams sem interrupções na comunicação da sua empresa.
            </p>
            <a href="/Parceiras/AudioCodes"
               class="inline-flex items-center gap-2 border border-smv-primary text-smv-primary hover:bg-smv-primary hover:text-white font-semibold px-5 py-2.5 rounded-full transition-colors text-sm">
                Ver soluções AudioCodes
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </a>
        </div>
        <div class="flex justify-center">
            <img src="/images/teams-ecosystem-light.png" alt="Teams Media Gateways"
                 class="w-full max-w-sm object-contain" />
        </div>
    </div>
</section>

<!-- ═══ CTA ═══ -->
<section class="py-14 px-4 bg-smv-bg border-t border-gray-100">
    <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-6">
        <div>
            <h3 class="text-xl font-bold text-smv-text mb-1">Pronto para habilitar o Teams Phone?</h3>
            <p class="text-smv-gray text-sm">Nossa equipe faz o diagnóstico e propõe o caminho mais eficiente para a sua empresa.</p>
        </div>
        <div class="flex flex-wrap gap-3 shrink-0">
            <a href="https://wa.me/@wa" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1db954] text-white font-bold px-5 py-3 rounded-full transition-colors text-sm">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
            </a>
            <a href="/#contato"
               class="inline-flex items-center gap-2 border border-smv-primary text-smv-primary hover:bg-smv-primary hover:text-white font-bold px-5 py-3 rounded-full transition-colors text-sm">
                Solicitar Consultoria
            </a>
        </div>
    </div>
</section>
