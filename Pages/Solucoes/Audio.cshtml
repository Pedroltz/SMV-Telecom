@page
@model SMVTelecom.Pages.Solucoes.AudioModel
@using SMVTelecom.Data
@{
    ViewData["Title"] = "Áudio Profissional";
    var produtos = ProdutoCatalog.Todos.Where(p => p.Categoria == "Áudio").ToList();
}

<section class="hero-gradient text-white py-20 px-4 text-center">
    <div class="max-w-3xl mx-auto">
        <span class="inline-block bg-white/10 text-blue-200 text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-4">Soluções</span>
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-4">Áudio Profissional</h1>
        <p class="text-blue-200 text-lg">Soluções de áudio corporativo para cada ambiente</p>
    </div>
</section>

<section class="py-16 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6">
            @foreach (var p in produtos)
            {
            <div class="flex flex-col items-center text-center gap-3">
                <div class="w-full aspect-square bg-gray-50 rounded-xl flex items-center justify-center overflow-hidden border border-gray-100">
                    <img src="~/images/produtos/@p.Img" alt="@p.Nome"
                         class="w-full h-full object-contain p-4"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
                    <svg style="display:none" class="w-16 h-16 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
                <p class="font-bold text-smv-primary text-sm leading-snug">@p.Nome</p>
                <a href="/Produto/@p.Slug"
                   class="bg-smv-accent hover:bg-smv-accentDark text-white text-xs font-semibold px-5 py-2 rounded-full transition-colors">
                    Leia mais
                </a>
            </div>
            }
        </div>
    </div>
</section>
