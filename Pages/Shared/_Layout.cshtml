@{
    var _path = Context.Request.Path.Value?.ToLower() ?? "/";
    Func<string, string> Nav = p => {
        bool active = p == "/" ? _path == "/" : _path.StartsWith(p.ToLower());
        return active
            ? "px-3 py-2 rounded-md text-sm font-medium text-smv-accent transition-colors"
            : "px-3 py-2 rounded-md text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors";
    };
    Func<string, string> MobNav = p => {
        bool active = p == "/" ? _path == "/" : _path.StartsWith(p.ToLower());
        return active
            ? "block px-4 py-2 text-sm font-medium text-smv-accent rounded-md"
            : "block px-4 py-2 text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 rounded-md";
    };
    bool _solucoes  = _path.StartsWith("/solucoes");
    bool _parceiras = _path.StartsWith("/parceiras");
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SMV Telecom</title>
    <meta name="description" content="SMV Telecom — Soluções em videoconferência, áudio, telefones e Microsoft Teams." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        smv: {
                            primary:     '#042C71',
                            dark:        '#021d4d',
                            accent:      '#CE4912',
                            accentDark:  '#a83a0e',
                            bg:          '#F0F4FF',
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="font-sans text-smv-text bg-white">

<!-- ═══════════════════════════ HEADER ═══════════════════════════ -->
<div class="fixed top-0 left-0 right-0 z-50" x-data="{ mobileOpen: false }">

    <!-- Utility bar -->
    <div class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-end items-center h-9 gap-6">
            <a href="tel:+5511985152865"
               class="flex items-center gap-1.5 text-xs text-gray-500 hover:text-gray-900 transition-colors">
                <svg class="w-3.5 h-3.5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                +55 11 98515-2865
            </a>
            <a href="mailto:contato@smvtelecom.com"
               class="flex items-center gap-1.5 text-xs text-gray-500 hover:text-gray-900 transition-colors">
                <svg class="w-3.5 h-3.5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                contato@smvtelecom.com
            </a>
        </div>
    </div>

    <!-- Main nav bar -->
    <header class="bg-smv-primary shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">

                <!-- Logo -->
                <a href="/" class="flex-shrink-0">
                    <img src="~/images/NovaLogo.png"
                         alt="SMV Telecom" class="h-11 object-contain" />
                </a>

                <!-- Desktop nav -->
                <nav class="hidden md:flex items-center gap-0.5">
                    <a href="/" class="@Nav("/")">Home</a>

                    <!-- Dropdown Soluções -->
                    <div class="relative" x-data="{ open: false }" @@mouseenter="open=true" @@mouseleave="open=false">
                        <button class="flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium @(_solucoes ? "text-smv-accent" : "text-white/80 hover:text-white hover:bg-white/10") transition-colors">
                            Soluções
                            <svg class="w-4 h-4 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>
                        <div x-show="open" x-cloak x-transition
                             class="absolute top-full left-0 mt-1 w-56 bg-white rounded-xl shadow-xl border border-gray-100 py-1 z-50">
                            <a href="/Solucoes/Videoconferencia" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-smv-bg hover:text-smv-primary transition-colors">Videoconferência</a>
                            <a href="/Solucoes/Audio"            class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-smv-bg hover:text-smv-primary transition-colors">Áudio</a>
                            <a href="/Solucoes/Telefones"        class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-smv-bg hover:text-smv-primary transition-colors">Telefones</a>
                            <a href="/Solucoes/MicrosoftTeams"   class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-smv-bg hover:text-smv-primary transition-colors">Microsoft Teams</a>
                        </div>
                    </div>

                    <!-- Dropdown Parceiras -->
                    <div class="relative" x-data="{ open: false }" @@mouseenter="open=true" @@mouseleave="open=false">
                        <button class="flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium @(_parceiras ? "text-smv-accent" : "text-white/80 hover:text-white hover:bg-white/10") transition-colors">
                            Parceiras
                            <svg class="w-4 h-4 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>
                        <div x-show="open" x-cloak x-transition
                             class="absolute top-full left-0 mt-1 w-48 bg-white rounded-xl shadow-xl border border-gray-100 py-1 z-50">
                            <a href="/Parceiras/Logitech"    class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-smv-bg hover:text-smv-primary transition-colors">Logitech</a>
                            <a href="/Parceiras/AudioCodes"  class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-smv-bg hover:text-smv-primary transition-colors">AudioCodes</a>
                            <a href="/Parceiras/PolyHP"      class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-smv-bg hover:text-smv-primary transition-colors">Poly / HP</a>
                        </div>
                    </div>

                    <a href="/QuemSomos" class="@Nav("/quemsomos")">Quem Somos</a>
                    <a href="/#contato"  class="px-3 py-2 rounded-md text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 transition-colors">Contato</a>
                </nav>

                <!-- CTA + Hamburger -->
                <div class="flex items-center gap-3">
                    <!-- Mobile hamburger -->
                    <button class="md:hidden p-2 rounded-md text-white/80 hover:text-white hover:bg-white/10 transition-colors"
                            @@click="mobileOpen = !mobileOpen" aria-label="Menu">
                        <svg x-show="!mobileOpen" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                        <svg x-show="mobileOpen" x-cloak class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Mobile menu -->
            <div x-show="mobileOpen" x-cloak x-transition class="md:hidden border-t border-white/10 py-3 space-y-1">
                <a href="/"          class="@MobNav("/")">Home</a>
                <p class="px-4 pt-2 text-xs font-semibold text-white/40 uppercase tracking-wider">Soluções</p>
                <a href="/Solucoes/Videoconferencia" class="block px-6 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-md">Videoconferência</a>
                <a href="/Solucoes/Audio"            class="block px-6 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-md">Áudio</a>
                <a href="/Solucoes/Telefones"        class="block px-6 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-md">Telefones</a>
                <a href="/Solucoes/MicrosoftTeams"   class="block px-6 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-md">Microsoft Teams</a>
                <p class="px-4 pt-2 text-xs font-semibold text-white/40 uppercase tracking-wider">Parceiras</p>
                <a href="/Parceiras/Logitech"   class="block px-6 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-md">Logitech</a>
                <a href="/Parceiras/AudioCodes" class="block px-6 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-md">AudioCodes</a>
                <a href="/Parceiras/PolyHP"     class="block px-6 py-2 text-sm text-white/70 hover:text-white hover:bg-white/10 rounded-md">Poly / HP</a>
                <a href="/QuemSomos" class="@MobNav("/quemsomos")">Quem Somos</a>
                <a href="/#contato"  class="block px-4 py-2 text-sm font-medium text-white/80 hover:text-white hover:bg-white/10 rounded-md">Contato</a>
            </div>
        </div>
    </header>
</div>

<!-- Spacer for fixed header (utility bar 36px + nav 64px = 100px) -->
<div class="h-[100px]"></div>

<!-- ═══════════════════════════ CONTENT ═══════════════════════════ -->
<main>
    @RenderBody()
</main>

<!-- ═══════════════════════════ FOOTER ═══════════════════════════ -->
<footer class="bg-smv-primary text-white/75 pt-12 pb-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
            <!-- Brand -->
            <div>
                <img src="~/images/NovaLogo.png"
                     alt="SMV Telecom" class="h-10 object-contain mb-3" />
                <p class="text-sm text-gray-400 leading-relaxed">
                    Especialistas em soluções de comunicação corporativa: videoconferência, áudio, telefonia e Microsoft Teams.
                </p>
            </div>
            <!-- Links -->
            <div>
                <h4 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Links Rápidos</h4>
                <ul class="space-y-2 text-sm">
                    <li><a href="/"           class="hover:text-white transition-colors">Início</a></li>
                    <li><a href="/QuemSomos"  class="hover:text-white transition-colors">Quem Somos</a></li>
                    <li><a href="/#contato"   class="hover:text-white transition-colors">Contato</a></li>
                    <li><a href="/Solucoes/Videoconferencia" class="hover:text-white transition-colors">Videoconferência</a></li>
                    <li><a href="/Solucoes/MicrosoftTeams"   class="hover:text-white transition-colors">Microsoft Teams</a></li>
                </ul>
            </div>
            <!-- Contact -->
            <div>
                <h4 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Contato</h4>
                <ul class="space-y-2 text-sm">
                    <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-white/50 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                        </svg>
                        <a href="https://wa.me/5511985152865" target="_blank" rel="noopener" class="hover:text-white transition-colors">+55 11 98515-2865</a>
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-white/50 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        <a href="mailto:contato@smvtelecom.com" class="hover:text-white transition-colors">contato@smvtelecom.com</a>
                    </li>
                    <li class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-white/50 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        <span>São Paulo, SP — Brasil</span>
                    </li>
                </ul>
            </div>
        </div>
        <hr class="border-white/20 mb-6" />
        <p class="text-center text-xs text-white/40">&copy; @DateTime.Now.Year SMV Telecom. Todos os direitos reservados.</p>
    </div>
</footer>

<!-- ═══════════════════════════ WhatsApp Float ═══════════════════════════ -->
<a href="https://wa.me/5511985152865" target="_blank" rel="noopener" class="whatsapp-float" aria-label="Falar no WhatsApp">
    <span class="wa-tooltip">Falar no WhatsApp</span>
    <span class="wa-btn">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
    </span>
</a>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
